{
    "[markdown]": {
        "editor.detectIndentation": false,
        "editor.insertSpaces": true,
        "editor.tabSize": 4
    },
    "[yaml]": {
        "editor.detectIndentation": false,
        "editor.insertSpaces": true,
        "editor.tabSize": 4
    },
    "json.schemas": [
        {
            "fileMatch": [
                "**/_meta.json"
            ],
            "url": "https://unpkg.com/@rspress/core@2.0.0/meta-json-schema.json"
        },
        {
            "fileMatch": [
                "**/_nav.json"
            ],
            "url": "https://unpkg.com/@rspress/core@2.0.0/nav-json-schema.json"
        }
    ]
}
